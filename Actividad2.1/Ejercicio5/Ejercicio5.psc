Algoritmo Ejercicio5
	Definir lado, perimetro, altura, area Como Real
	Escribir "Escribe el lado del triangulo equilatero:"
	Leer lado
	perimetro = lado * 3
	altura = (lado*rc(3))/2
	area = (lado*altura)/2
	Escribir "Perimetro: ", perimetro
	Escribir "Altura: ", altura
	Escribir "Area: ", area
FinAlgoritmo
